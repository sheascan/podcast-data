{
    "search.exclude": {
        "**/venv/**": true,
        "**/podcast_data/**": true,
        "**/data/**": true,
        "**/*.mp3": true,
        "**/*.json": true
    },
    "files.watcherExclude": {
        "**/venv/**": true,
        "**/podcast_data/**": true,
        "**/.git/objects/**": true,
        "**/data/**": true
    },
    "files.exclude": {
        "**/podcast_data/**": true
    },
    "python.analysis.exclude": [
        "**/venv/**",
        "**/data/**",
        "**/podcast_data/**"
    ],
    "python.analysis.indexing": false,
    "editor.largeFileOptimizations": true,
    "git.autorefresh": false,
    "git.scanRepositories": [
        "~/podcast_studio
    ],
    "git.detectSubmodules": false
}
